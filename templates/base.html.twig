<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="{{ asset('favicon.png') }}">
    <title>{% block title %}Knowledge Learning{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('styles/base.css') }}">
</head>
<body>

<header class="header">
    <div class="logo">
        <img src="{{ asset('logo.jpg') }}" alt="Knowledge Learning" height="80">
    </div>

    <nav class="nav">
        <ul class="menu">

            <li class="menu-item">
                <a class="menu-btn" href="{{ path('app_home') }}">Accueil</a>
            </li>

            <li class="menu-item">
                <button class="menu-btn">Musique</button>
                <ul class="submenu">
                    <li>Cursus guitare</li>
                    <li>Cursus piano</li>
                </ul>
            </li>

            <li class="menu-item">
                <button class="menu-btn">Informatique</button>
                <ul class="submenu">
                    <li>Cursus d’initiation au développement web</li>
                </ul>
            </li>

            <li class="menu-item">
                <button class="menu-btn">Jardinage</button>
                <ul class="submenu">
                    <li>Cursus d’initiation au jardinage</li>
                </ul>
            </li>

            <li class="menu-item">
                <button class="menu-btn">Cuisine</button>
                <ul class="submenu">
                    <li>Cursus d’initiation à la cuisine</li>
                    <li>Cursus d’initiation à l’art du dressage culinaire</li>
                </ul>
            </li>

            <li class="menu-item">
                <button class="menu-btn">
                    {% if app.user %}
                        Bonjour {{ app.user.name }}
                    {% else %}
                        Compte
                    {% endif %}
                </button>

                <ul class="submenu">
                    {% if app.user %}
                        <li><a href="{{ path('app_logout') }}">Se déconnecter</a></li>
                    {% else %}
                        <li><a href="{{ path('app_login') }}">Se connecter</a></li>
                        <li><a href="{{ path('app_register') }}">S'inscrire</a></li>
                    {% endif %}
                </ul>
            </li>

        </ul>
    </nav>
</header>

<main class="main">
    {% block body %}{% endblock %}
</main>

<footer class="footer">
    <p>© {{ "now"|date("Y") }} Knowledge Learning - Tous droits réservés</p>
</footer>

<script src="{{ asset('js/menu.js') }}"></script>
</body>
</html>